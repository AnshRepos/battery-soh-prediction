# Flask Configuration
FLASK_ENV=development
FLASK_APP=wsgi.py
FLASK_DEBUG=True

# Database
DATABASE_URL=sqlite:///battery.db

# API Configuration
API_HOST=0.0.0.0
API_PORT=5000
API_SECRET_KEY=your-secret-key-here-change-in-production

# Model Configuration
MODEL_PATH=./models
BATCH_SIZE=32

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# CORS Settings
CORS_ORIGINS=http://localhost:3000,http://localhost:5000